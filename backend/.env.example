# Skopiuj do .env: cp .env.example .env
# W Dockerze DATABASE_URL i APP_ENV są też ustawiane w docker-compose.yml

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_to_random_32_char_string
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Host "db" = nazwa serwisu w docker-compose (wewnątrz sieci Docker)
DATABASE_URL="postgresql://app:app@db:5432/subscriptions?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_jwt_passphrase
###< lexik/jwt-authentication-bundle ###

###> openrouter ###
# Model AI do importu wyciągu — klucz API podaje użytkownik (BYOK), nie trafia do .env
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
###< openrouter ###
